# FaceTomato backend environment example
#
# 使用说明：
# 1. 复制本文件为 backend/.env
# 2. 注释请单独写在上一行，不要写成 KEY=value # comment
# 3. 启动前至少补齐当前 MODEL_PROVIDER 对应的 API Key

# =========================
# Application
# =========================
APP_HOST=0.0.0.0
APP_PORT=6522
CORS_ORIGINS=http://localhost:5569,http://127.0.0.1:5569
MAX_UPLOAD_MB=10

# =========================
# OCR（可选）
# =========================
# 智谱 OCR API Key
# ZHIPU_APIKEY=your-zhipu-api-key

# =========================
# LLM provider（必选）
# 支持：openai / google_genai / anthropic
# =========================
MODEL_PROVIDER=openai

# OpenAI / OpenAI-Compatible API
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini API
# GOOGLE_API_KEY=
# GOOGLE_MODEL=gemini-2.0-flash

# Anthropic Claude API
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# =========================
# Speech-to-Text（可选）
# VOLCENGINE_SPEECH_MODE 可选值：nostream（停止后返回最终结果），streaming（实时返回），streaming_async（优化版实时返回）
# 对应的 VOLCENGINE_SPEECH_BASE_URL 分别是：bigmodel_nostream、bigmodel、bigmodel_async
# 推荐使用 streaming_async 模式，能在保证响应速度的同时，提供更流畅的实时转写体验
# =========================
VOLCENGINE_SPEECH_BASE_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
VOLCENGINE_SPEECH_APP_KEY=you_api_key
VOLCENGINE_SPEECH_ACCESS_KEY=you_access_key
VOLCENGINE_SPEECH_RESOURCE_ID=volc.seedasr.sauc.duration
VOLCENGINE_SPEECH_MODE=streaming_async

# =========================
# Rate Limiter
# =========================
# 默认情况下不必设置，直接使用代码内置默认值：
# RATE_LIMIT_REQUESTS_PER_SECOND=20
# RATE_LIMIT_CHECK_EVERY_N_SECONDS=5
# RATE_LIMIT_MAX_BUCKET_SIZE=20
#
# 如果你希望使用更严格的限流，可取消下面三行注释：
# 0.1 req/s 约等于 6 rpm
# RATE_LIMIT_REQUESTS_PER_SECOND=0.1
# 每 0.1 秒检查一次请求队列
# RATE_LIMIT_CHECK_EVERY_N_SECONDS=0.1
# 最多允许 10 个积压请求，超过直接拒绝
# RATE_LIMIT_MAX_BUCKET_SIZE=10

# =========================
# Interview data
# =========================
INTERVIEW_DB_PATH=data/interviews.db
INTERVIEW_ZVEC_INDEX_PATH=data/interview_zvec

# =========================
# Mock interview
# =========================
# 匿名 mock interview 本地恢复 token TTL（分钟）
MOCK_INTERVIEW_SESSION_TTL_MINUTES=1440
# 计划生成超时时间（秒）
MOCK_INTERVIEW_PLAN_TIMEOUT_SECONDS=600

# Mock interview RAG（可选能力）
# 详细说明见：docs/backend/rag-config.md
# 本地安装层：若需要本地 RAG / 索引能力，请先执行：uv sync --extra rag
# Docker 安装层：若使用 Docker 构建镜像，请在 build/up --build 前提供 BACKEND_INSTALL_RAG=true
# 运行时层：MOCK_INTERVIEW_RAG 只控制进程启动后的开关，不参与镜像构建
MOCK_INTERVIEW_RAG=false

# 仅影响召回数量和 dense/sparse 重排权重；通常保持默认即可
INTERVIEW_RAG_TOPK=5
INTERVIEW_RAG_CANDIDATE_TOPK=12
INTERVIEW_RAG_DENSE_WEIGHT=1.2
INTERVIEW_RAG_SPARSE_WEIGHT=1.0

# =========================
# Dense embedding（推荐：local_hf_qwen3）
# 若无 GPU，可将 DEVICE 改为 cpu
# =========================
INTERVIEW_DENSE_EMBEDDING_PROVIDER=local_hf_qwen3
INTERVIEW_DENSE_EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
INTERVIEW_DENSE_EMBEDDING_MODEL_SOURCE=huggingface
INTERVIEW_DENSE_EMBEDDING_DEVICE=cuda
INTERVIEW_DENSE_EMBEDDING_NORMALIZE=true

# =========================
# Sparse embedding（推荐：bm25）
# =========================
INTERVIEW_SPARSE_EMBEDDING_PROVIDER=bm25
INTERVIEW_SPARSE_EMBEDDING_LANGUAGE=zh
# INTERVIEW_SPARSE_EMBEDDING_BM25_B=
# INTERVIEW_SPARSE_EMBEDDING_BM25_K1=
